{% extends 'base.html.twig' %}

{% block title %}Prestations — MpSonorisation{% endblock %}

{% block body %}

{# ===== HERO ===== #}
<section class="bg-dark text-white py-5">
    <div class="container">
        <p class="display-5 fw-bold">
            Nos prestations techniques pour vos événements.
        </p>
    </div>
</section>

{# ===== PRÉSENTATION ===== #}
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-7">
                <h2 class="fw-bold">Qui sommes-nous ?</h2>
                <p class="mt-3">Lorem ipsum dolor sit amet consectetur adipisicing elit. Explicabo quaerat laborum nostrum id quibusdam minima repellat sunt.</p>
                <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Explicabo quaerat laborum nostrum id quibusdam minima repellat sunt.</p>
            </div>
            <div class="col-md-5">
                <img src="{{ asset('images/prestation-about.jpg') }}" alt="MpSonorisation" class="img-fluid rounded shadow-sm">
            </div>
        </div>
    </div>
</section>

{# ===== SPECTACLE ===== #}
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-5">
                <img src="{{ asset('images/prestation-spectacle.jpg') }}" alt="Spectacle" class="img-fluid rounded shadow-sm">
            </div>
            <div class="col-md-7">
                <h2 class="fw-bold">Spectacle vivant</h2>
                <p class="mt-3">Concerts, festivals, représentations théâtrales... Nous mettons à disposition notre expertise technique pour sublimer vos spectacles.</p>
                <ul class="mt-3">
                    <li>Sonorisation de scène</li>
                    <li>Éclairage scénique</li>
                    <li>Régie son et lumière</li>
                </ul>
            </div>
        </div>
    </div>
</section>

{# ===== LOCATION ===== #}
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-7">
                <h2 class="fw-bold">Location de matériel</h2>
                <p class="mt-3">Besoin de matériel pour votre événement ? Nous proposons à la location un large catalogue de matériel son, lumière et vidéo.</p>
                <ul class="mt-3">
                    <li>Enceintes, amplis, tables de mixage</li>
                    <li>Jeux de lumières, lyres, projecteurs</li>
                    <li>Écrans, vidéoprojecteurs</li>
                </ul>
                <a href="#" class="btn btn-dark mt-4">Voir le catalogue</a>
            </div>
            <div class="col-md-5">
                <img src="{{ asset('images/prestation-location.jpg') }}" alt="Location" class="img-fluid rounded shadow-sm">
            </div>
        </div>
    </div>
</section>

{% endblock %}