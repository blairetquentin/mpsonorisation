{% extends 'base.html.twig' %}

{% block title %}{{ materiel.libelle }} — MpSonorisation{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_catalogue') }}">Catalogue</a>
            </li>
            <li class="breadcrumb-item text-muted">
                {{ materiel.sousCategorie.categorie.libelle }}
            </li>
            <li class="breadcrumb-item text-muted">
                {{ materiel.sousCategorie.libelle }}
            </li>
            <li class="breadcrumb-item active">{{ materiel.libelle }}</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-5">
            {% if materiel.urlMateriel %}
                <img src="{{ asset(materiel.urlMateriel) }}"
                     class="img-fluid rounded shadow"
                     alt="{{ materiel.libelle }}">
            {% else %}
                <div class="bg-secondary rounded d-flex align-items-center justify-content-center"
                     style="height: 300px;">
                    <span class="text-white fs-5">Pas d'image</span>
                </div>
            {% endif %}
        </div>

        <div class="col-md-7">
            <h1 class="mb-2">{{ materiel.libelle }}</h1>
            <p class="text-muted mb-4">Réf. {{ materiel.reference }}</p>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item d-flex justify-content-between">
                    <span>Catégorie</span>
                    <strong>{{ materiel.sousCategorie.categorie.libelle }}</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Sous-catégorie</span>
                    <strong>{{ materiel.sousCategorie.libelle }}</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Stock disponible</span>
                    <strong>{{ materiel.stockDispo }} / {{ materiel.stockTotal }}</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Disponibilité</span>
                    {% if materiel.stockDispo > 0 %}
                        <span class="badge bg-success align-self-center">Disponible</span>
                    {% else %}
                        <span class="badge bg-danger align-self-center">Indisponible</span>
                    {% endif %}
                </li>
            </ul>

            {% if app.user %}
                <a href="{{ path('app_panier_add', {id: materiel.id}) }}"
                   class="btn btn-primary btn-lg w-100">
                    Ajouter au panier
                </a>
            {% else %}
                <a href="{{ path('app_login') }}"
                   class="btn btn-outline-primary btn-lg w-100">
                    Se connecter pour ajouter au panier
                </a>
            {% endif %}

            <a href="{{ path('app_catalogue') }}" class="btn btn-link mt-2">
                ← Retour au catalogue
            </a>
        </div>
    </div>
</div>
{% endblock %}