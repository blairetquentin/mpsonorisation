{% extends 'base.html.twig' %}

{% block title %}Nouveau plan de scène{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">🎸 Nouveau plan de scène</h1>

    {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.nom_evenement) }}
            {{ form_widget(form.nom_evenement) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.date_evenement) }}
            {{ form_widget(form.date_evenement) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.nom_artiste) }}
            {{ form_widget(form.nom_artiste) }}
        </div>

        <hr>
        <h2 class="h5 mb-3">🎵 Musiciens</h2>

        <div id="musiciens-container"></div>

        <button type="button" class="btn btn-outline-secondary mb-4" id="btn-add-musicien">
            + Ajouter un musicien
        </button>

        <script>
            const instruments = {{ instruments|map(i => {
                'id': i.id,
                'libelle': i.libelle
            })|json_encode|raw }};
        </script>

        {{ form_widget(form.submit) }}

    {{ form_end(form) }}
</div>

<style>
    .dropdown-instruments {
        position: absolute;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        max-height: 200px;
        overflow-y: auto;
        z-index: 1000;
        width: 250px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .dropdown-instruments .dropdown-item {
        padding: 0.5rem 1rem;
        cursor: pointer;
    }

    .dropdown-instruments .dropdown-item:hover {
        background-color: #f8f9fa;
    }

    .instrument-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background-color: #0d6efd;
        color: white;
        border-radius: 1rem;
        padding: 0.25rem 0.75rem;
        font-size: 0.85rem;
    }

    .instrument-chip button {
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        padding: 0;
        font-size: 0.85rem;
        line-height: 1;
    }
</style>

<script>
let count = 0;

function addMusicien() {
    const container = document.getElementById('musiciens-container');

    const div = document.createElement('div');
    div.className = 'musicien-row border rounded p-3 mb-3';
    div.setAttribute('data-index', count);
    div.innerHTML = `
        <div class="d-flex gap-2 align-items-center mb-2">
            <input
                type="text"
                name="musiciens[${count}][nom]"
                placeholder="Nom du musicien"
                class="form-control"
                required
            >
            <button
                type="button"
                class="btn btn-outline-danger btn-sm"
                onclick="this.closest('.musicien-row').remove()"
            >
                ✕
            </button>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center chips-container mb-2" data-index="${count}"></div>

        <div class="position-relative">
            <input
                type="text"
                class="form-control form-control-sm instrument-search"
                placeholder="Rechercher un instrument..."
                oninput="filtrerInstruments(this, ${count})"
                onfocus="filtrerInstruments(this, ${count})"
                autocomplete="off"
            >
            <div class="dropdown-instruments" id="dropdown-${count}" style="display:none;"></div>
        </div>
    `;

    container.appendChild(div);
    count++;
}

function filtrerInstruments(input, index) {
    // On récupère ce que l'utilisateur a tapé en minuscules
    const recherche = input.value.toLowerCase();
    const dropdown = document.getElementById(`dropdown-${index}`);

    // On filtre les instruments selon la recherche
    const resultats = instruments.filter(i => i.libelle.toLowerCase().includes(recherche));

    if (resultats.length === 0) {
        dropdown.style.display = 'none';
        return;
    }

    // On vide et on remplit le dropdown
    dropdown.innerHTML = '';
    resultats.forEach(i => {
        const item = document.createElement('div');
        item.className = 'dropdown-item';
        item.textContent = i.libelle;

        // Double clic → on ajoute l'instrument comme chip
        item.onclick = () => ajouterInstrument(index, i.id, i.libelle, input, dropdown);

        dropdown.appendChild(item);
    });

    dropdown.style.display = 'block';
}

function ajouterInstrument(index, id, libelle, input, dropdown) {
    const chipsContainer = document.querySelector(`.chips-container[data-index="${index}"]`);

    // On vérifie que l'instrument n'est pas déjà ajouté
    const dejaAjoute = document.querySelector(
        `input[type="hidden"][data-id="${id}"][data-index="${index}"]`
    );
    if (dejaAjoute) {
        dropdown.style.display = 'none';
        input.value = '';
        return;
    }

    // On crée le chip visible
    const chip = document.createElement('div');
    chip.className = 'instrument-chip';
    chip.innerHTML = `
        ${libelle}
        <button type="button" onclick="retirerInstrument(this, '${id}', '${index}')">✕</button>
    `;
    chipsContainer.appendChild(chip);

    // On crée l'input caché pour envoyer la valeur en POST
    const hiddenInput = document.createElement('input');
    hiddenInput.type = 'hidden';
    hiddenInput.name = `musiciens[${index}][instrument_id][]`;
    hiddenInput.value = id;
    hiddenInput.dataset.id = id;
    hiddenInput.dataset.index = index;
    chipsContainer.appendChild(hiddenInput);

    // On ferme le dropdown et on vide la recherche
    dropdown.style.display = 'none';
    input.value = '';
}

function retirerInstrument(bouton, id, index) {
    // On retire le chip
    bouton.closest('.instrument-chip').remove();

    // On retire l'input caché correspondant
    const input = document.querySelector(
        `input[type="hidden"][data-id="${id}"][data-index="${index}"]`
    );
    if (input) input.remove();
}

// On ferme les dropdowns si on clique ailleurs
document.addEventListener('click', (e) => {
    if (!e.target.classList.contains('instrument-search')) {
        document.querySelectorAll('.dropdown-instruments').forEach(d => d.style.display = 'none');
    }
});

document.getElementById('btn-add-musicien').addEventListener('click', addMusicien);

// Une ligne par défaut au chargement
addMusicien();
</script>
{% endblock %}