{% extends 'base.html.twig' %}

{% block title %}Module Scène{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">Module Scène</h1>

    {% if not connecte %}
        <div class="alert alert-warning">
            <strong>Accès limité.</strong>
            Pour créer un plan de scène, vous devez avoir un compte.<br>
            <a href="{{ path('app_register') }}" class="btn btn-primary mt-2">
                Créez un compte
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-outline-secondary mt-2">
                Se connecter
            </a>
        </div>

    {% else %}
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h5 mb-0">Mes plans de scène</h2>
            <a href="{{ path('app_scene_form') }}" class="btn btn-primary">
                + Nouveau plan
            </a>
        </div>

        {% if scenes is empty %}
            <p class="text-muted">Vous n'avez pas encore de plan de scène.</p>

        {% else %}
            <div class="row g-3">
                {% for scene in scenes %}
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ scene.nomEvenement }}</h5>
                            <p class="card-text text-muted">
                                {{ scene.nomArtiste }}<br>
                                {{ scene.dateEvenement|date('d/m/Y') }}
                            </p>
                            <span class="badge {{ scene.statut ? 'bg-success' : 'bg-secondary' }}">
                                {{ scene.statut ? 'Soumis' : 'Brouillon' }}
                            </span>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            {% if not scene.statut %}
                                <a href="{{ path('app_scene_form_edit', {id: scene.id}) }}"
                                   class="btn btn-sm btn-outline-secondary">
                                    Modifier
                                </a>
                                <form method="POST" action="{{ path('app_scene_delete', {id: scene.id}) }}"
                                    onsubmit="return confirm('Supprimer ce plan ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ scene.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Supprimer
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}